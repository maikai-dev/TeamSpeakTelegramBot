# -------- App --------
ENVIRONMENT=dev
LOG_LEVEL=INFO

# -------- Telegram --------
BOT_TOKEN=replace_me
BOT_ADMIN_IDS=123456789
BOOTSTRAP_ADMIN_TG_IDS=123456789
BOT_RATE_LIMIT_PER_MINUTE=25
BOT_SENSITIVE_RATE_LIMIT_PER_MINUTE=6
BOT_MAX_TTS_TEXT_LENGTH=280

# -------- Database / Redis --------
DATABASE_URL=postgresql+asyncpg://ts3bot:ts3bot@postgres:5432/ts3bot
REDIS_URL=redis://redis:6379/0

# -------- TeamSpeak ServerQuery --------
TS3_HOST=127.0.0.1
TS3_QUERY_PORT=10011
TS3_QUERY_LOGIN=serveradmin
TS3_QUERY_PASSWORD=replace_me
TS3_VIRTUAL_SERVER_ID=1
TS3_QUERY_NICKNAME=tg-control-bot
TS3_POLL_INTERVAL_SECONDS=8
TS3_EVENT_QUEUE_SIZE=2000
TS3_CHANNEL_ALERT_IDS=

# -------- ChatWatch --------
CHATWATCH_ENABLED_BY_DEFAULT=true
CHATWATCH_ALLOWED_TYPES=server,channel,private
CHATWATCH_CHANNEL_WHITELIST=
CHATWATCH_IGNORE_QUERY_CLIENTS=true

# -------- Notifications --------
NOTIFY_ANTISPAM_SECONDS=20
NOTIFY_QUIET_HOURS=

# -------- TTS --------
TTS_PROVIDER=gtts
TTS_LANGUAGE=ru
TTS_AUDIO_DIR=/tmp/tts-audio

# -------- Voice backend --------
# command | ts3audiobot | disabled
VOICE_BACKEND=command
VOICE_WORKER_CMD=python /app/docker/voice_worker_example.py
VOICE_COMMAND_TIMEOUT_SECONDS=45

# Optional TS3AudioBot API
TS3_AUDIOBOT_BASE_URL=
TS3_AUDIOBOT_API_KEY=
TS3_AUDIOBOT_JOIN_ENDPOINT=/api/bot/join
TS3_AUDIOBOT_PLAY_ENDPOINT=/api/bot/play_tts
TS3_AUDIOBOT_LEAVE_ENDPOINT=/api/bot/leave

# -------- Reports --------
DAILY_REPORT_HOUR_MSK=10
WEEKLY_REPORT_WEEKDAY=1
